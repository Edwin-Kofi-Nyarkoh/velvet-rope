generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GUEST
  ATTENDEE
  ORGANIZER
  STAFF
  VENDOR
  ADMIN
  SUPER_ADMIN
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum TicketKind {
  REGULAR
  VIP
  VVIP
  TABLE
}

enum TicketStatus {
  ACTIVE
  USED
  EXPIRED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum SeatStatus {
  AVAILABLE
  RESERVED
  ASSIGNED
  BLOCKED
}

enum SocialProvider {
  FACEBOOK
  LINKEDIN
  X
  INSTAGRAM
  TIKTOK
}

enum VipVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum MessageAudience {
  STAFF
  VENDORS
  ALL
}

enum VendorTransactionStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

model User {
  id                String            @id @default(uuid())
  email             String            @unique
  passwordHash      String
  role              Role              @default(ATTENDEE)
  emailVerifiedAt   DateTime?
  failedLoginCount  Int               @default(0)
  lockedUntil       DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  profile           Profile?
  organizedEvents   Event[]           @relation("OrganizerEvents")
  tickets           Ticket[]
  orders            Order[]
  invitations       Invitation[]      @relation("InviteeInvitations")
  sentInvitations   Invitation[]      @relation("SenderInvitations")
  checkIns          CheckIn[]         @relation("StaffCheckIns")
  staffPermissions  StaffPermission[]
  vendor            Vendor?
  notifications     Notification[]
  emailVerifications EmailVerification[]
  socialAccounts    SocialAccount[]
  socialConnections SocialConnection[] @relation("UserSocialConnections")
  socialFriendOf    SocialConnection[] @relation("FriendSocialConnections")
  vendorTransactions VendorTransaction[] @relation("AttendeeVendorTransactions")
  eventMessages     EventMessage[]
  nfcCredentials    NfcCredential[]
  vipVerifications  VipVerification[]
  passwordResets    PasswordReset[]

  @@index([role])
  @@index([emailVerifiedAt])
}

model EmailVerification {
  id         String   @id @default(uuid())
  userId     String
  email      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([expiresAt, consumedAt])
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  fullName    String
  phone       String?
  avatarUrl   String?
  companyName String?
  bio         String?
  city        String?
  country     String?  @default("Ghana")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EventCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  events      Event[]
}

model Event {
  id          String            @id @default(uuid())
  organizerId String
  categoryId  String
  title       String
  slug        String            @unique
  description String
  bannerUrl   String
  venueName   String
  address     String
  city        String
  country     String            @default("Ghana")
  startsAt    DateTime
  endsAt      DateTime
  isPrivate   Boolean           @default(false)
  isSeries    Boolean           @default(false)
  isFeatured  Boolean           @default(false)
  isPopular   Boolean           @default(false)
  popularityScore Int           @default(0)
  viewCount    Int              @default(0)
  status      EventStatus       @default(DRAFT)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  organizer   User              @relation("OrganizerEvents", fields: [organizerId], references: [id])
  category    EventCategory     @relation(fields: [categoryId], references: [id])
  ticketTypes TicketType[]
  tickets     Ticket[]
  orders      Order[]
  payments    Payment[]
  invitations Invitation[]
  checkIns    CheckIn[]
  staff       StaffPermission[]
  vendors     Vendor[]
  tables      Table[]
  seats       Seat[]
  socialMentions SocialMention[]
  vendorTransactions VendorTransaction[]
  eventMessages EventMessage[]
  nfcCredentials NfcCredential[]

  @@index([organizerId])
  @@index([categoryId])
  @@index([startsAt])
  @@index([status, isPrivate])
  @@index([isPopular, popularityScore])
}

model TicketType {
  id           String     @id @default(uuid())
  eventId      String
  name         String
  kind         TicketKind
  price        Decimal    @db.Decimal(12, 2)
  currency     String     @default("GHS")
  quantity     Int
  soldQuantity Int        @default(0)
  salesStartAt DateTime?
  salesEndAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  event        Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets      Ticket[]
  orders       Order[]
  orderItems   OrderItem[]

  @@index([eventId, kind])
}

model Order {
  id           String      @id @default(uuid())
  userId       String
  eventId      String
  ticketTypeId String
  reference    String      @unique
  quantity     Int
  amount       Decimal     @db.Decimal(12, 2)
  currency     String      @default("GHS")
  status       OrderStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id])
  event        Event       @relation(fields: [eventId], references: [id])
  ticketType   TicketType  @relation(fields: [ticketTypeId], references: [id])
  payment      Payment?
  tickets      Ticket[]
  items        OrderItem[]

  @@index([userId, status])
  @@index([eventId])
}

model OrderItem {
  id           String     @id @default(uuid())
  orderId      String
  ticketTypeId String
  quantity     Int
  unitPrice    Decimal    @db.Decimal(12, 2)
  currency     String     @default("GHS")
  createdAt    DateTime   @default(now())
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id])

  @@index([orderId])
  @@index([ticketTypeId])
}

model Ticket {
  id            String       @id @default(uuid())
  userId        String
  eventId       String
  ticketTypeId  String
  orderId       String?
  code          String       @unique
  qrCodePayload String       @unique
  status        TicketStatus @default(ACTIVE)
  issuedAt      DateTime     @default(now())
  usedAt        DateTime?
  user          User         @relation(fields: [userId], references: [id])
  event         Event        @relation(fields: [eventId], references: [id])
  ticketType    TicketType   @relation(fields: [ticketTypeId], references: [id])
  order         Order?       @relation(fields: [orderId], references: [id])
  checkIn       CheckIn?
  seat          Seat?
  nfcCredential NfcCredential?

  @@index([userId, status])
  @@index([eventId, status])
}

model Payment {
  id                 String        @id @default(uuid())
  orderId            String        @unique
  eventId            String
  provider           String        @default("PAYSTACK")
  reference          String        @unique
  providerReference  String?
  amount             Decimal       @db.Decimal(12, 2)
  currency           String        @default("GHS")
  status             PaymentStatus @default(PENDING)
  authorizationUrl   String?
  rawResponse        Json?
  verifiedAt         DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  order              Order         @relation(fields: [orderId], references: [id])
  event              Event         @relation(fields: [eventId], references: [id])
}

model Invitation {
  id            String           @id @default(uuid())
  eventId       String
  inviteeId     String?
  sentById      String
  email         String
  recipientName String
  message       String?
  token         String           @unique
  status        InvitationStatus @default(PENDING)
  respondedAt   DateTime?
  expiresAt     DateTime
  createdAt     DateTime         @default(now())
  event         Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invitee       User?            @relation("InviteeInvitations", fields: [inviteeId], references: [id])
  sentBy        User             @relation("SenderInvitations", fields: [sentById], references: [id])

  @@index([eventId, status])
  @@index([email])
}

model CheckIn {
  id          String   @id @default(uuid())
  eventId     String
  ticketId    String   @unique
  staffId     String
  gate        String?
  checkedInAt DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id])
  ticket      Ticket   @relation(fields: [ticketId], references: [id])
  staff       User     @relation("StaffCheckIns", fields: [staffId], references: [id])

  @@index([eventId, checkedInAt])
  @@index([staffId])
}

model StaffPermission {
  id             String   @id @default(uuid())
  userId         String
  eventId        String
  canScanTickets Boolean  @default(true)
  canManageGuests Boolean @default(false)
  canViewRevenue Boolean  @default(false)
  canManageVendors Boolean @default(false)
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Vendor {
  id          String   @id @default(uuid())
  userId      String   @unique
  eventId     String?
  businessName String
  category    String
  description String?
  phone       String?
  email       String?
  rating      Decimal? @db.Decimal(3, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  transactions VendorTransaction[]
}

model Table {
  id        String   @id @default(uuid())
  eventId   String
  name      String
  capacity  Int
  zone      String?
  seats     Seat[]
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, name])
}

model Seat {
  id        String     @id @default(uuid())
  eventId   String
  tableId   String?
  ticketId  String?    @unique
  label     String
  status    SeatStatus @default(AVAILABLE)
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  table     Table?     @relation(fields: [tableId], references: [id], onDelete: SetNull)
  ticket    Ticket?    @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  createdAt DateTime   @default(now())

  @@unique([eventId, label])
  @@index([eventId, status])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model SocialAccount {
  id            String                @id @default(uuid())
  userId        String
  provider      SocialProvider
  providerUserId String?
  handle        String
  displayName   String
  avatarUrl     String?
  followerCount Int                   @default(0)
  vipStatus     VipVerificationStatus @default(UNVERIFIED)
  verifiedAt    DateTime?
  metadata      Json?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  vipVerifications VipVerification[]

  @@unique([provider, handle])
  @@index([userId, provider])
  @@index([vipStatus])
}

model SocialConnection {
  id           String         @id @default(uuid())
  userId       String
  friendUserId String
  provider     SocialProvider
  createdAt    DateTime       @default(now())
  user         User           @relation("UserSocialConnections", fields: [userId], references: [id], onDelete: Cascade)
  friend       User           @relation("FriendSocialConnections", fields: [friendUserId], references: [id], onDelete: Cascade)

  @@unique([userId, friendUserId, provider])
  @@index([friendUserId])
}

model SocialMention {
  id           String         @id @default(uuid())
  eventId      String
  provider     SocialProvider
  hashtag      String
  content      String
  authorHandle String
  reach        Int            @default(0)
  engagement   Int            @default(0)
  sentiment    String         @default("neutral")
  postedAt     DateTime       @default(now())
  event        Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, provider])
  @@index([hashtag])
}

model VendorTransaction {
  id                String                  @id @default(uuid())
  eventId           String
  vendorId          String
  attendeeId        String
  reference         String                  @unique
  description       String
  amount            Decimal                 @db.Decimal(12, 2)
  currency          String                  @default("GHS")
  status            VendorTransactionStatus @default(PENDING)
  provider          String                  @default("IN_APP")
  providerReference String?
  paidAt            DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  event             Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendor            Vendor                  @relation(fields: [vendorId], references: [id])
  attendee          User                    @relation("AttendeeVendorTransactions", fields: [attendeeId], references: [id])

  @@index([eventId, status])
  @@index([vendorId, status])
  @@index([attendeeId, status])
}

model EventMessage {
  id        String          @id @default(uuid())
  eventId   String
  senderId  String
  audience  MessageAudience
  subject   String
  body      String
  createdAt DateTime        @default(now())
  event     Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sender    User            @relation(fields: [senderId], references: [id])

  @@index([eventId, audience])
  @@index([senderId])
}

model NfcCredential {
  id         String   @id @default(uuid())
  ticketId   String   @unique
  eventId    String
  userId     String
  token      String   @unique
  label      String?
  active     Boolean  @default(true)
  issuedAt   DateTime @default(now())
  lastUsedAt DateTime?
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId, active])
  @@index([userId])
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt, usedAt])
}

model VipVerification {
  id              String                @id @default(uuid())
  userId          String
  socialAccountId String?
  provider        SocialProvider
  handle          String
  status          VipVerificationStatus @default(PENDING)
  evidenceUrl     String?
  reviewerNote    String?
  submittedAt     DateTime              @default(now())
  reviewedAt      DateTime?
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccount   SocialAccount?        @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([provider, handle])
}
